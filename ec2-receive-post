from flask import Flask, request
import pymysql
import os
from dotenv import load_dotenv

load_dotenv()

main = Flask(__name__)

DB_HOST = os.dotenv('DB_HOST')
DB_USER = os.dotenv('DB_USER')
DB_PASSWORD = os.dotenv('DB_PASSWORD')
DB_NAME = os.dotenv('DB_NAME')

#/にpost通信が来たら関数実行（ルーティング）
@main.route('/sensor', methods=['post'])
def receive():
    #Jsonデータを取得
    data = request.get_json()
    device_name = data.get('device_name')
    status = data.get('status')

    #RDSへ接続
    connection = pymysql.connect(
        host=DB_HOST
        user=DB_USER
        password=DB_PASSWORD
        database=DB_NAME
        charset='utf8mb4' #文字を正しく読み取ることができるRDSで定められた設定
    )
    
    try:
        #cursorでSQLの実行
        with connection.cursor() as cursor: #cursorはデータベースにSQLを送るための窓口
            sql = """
            INSERT INTO sensor_logs(device_name, status) #sensor_logsテーブルにデータを追加する命令文
            VALUES (%s, %s) #後に値を入れる(detected, pico_w_01)

            cursor.execute(sql,(device_name, status)) #ここでSQLを実行する
        #保存の確定
        connection.commit()
    #何があっても必ず実行するという命令文
    finally:
        connection.close()

    return '保存完了' 200

if __name__ == '__main__':
    #hostはipアドレスを示しており、全てのipアドレスを許可している
    main.run(host='0.0.0.0', port=5000)

